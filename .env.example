# ─── WhatsApp Business Cloud API ─────────────────────────────────────────────
# Meta Business Manager → WhatsApp → API Setup
WHATSAPP_TOKEN=          # Token permanente del System User
WHATSAPP_PHONE_ID=       # Phone Number ID
WHATSAPP_APP_SECRET=     # App Secret (Meta App → Settings → Basic)
VERIFY_TOKEN=            # Token de verificación del webhook (tú lo defines)

# ─── Clínica ──────────────────────────────────────────────────────────────────
CLINICA_NOMBRE=Clínica Dental Dr. Martínez
CLINICA_TELEFONO=+56 2 2345 6789
CLINICA_EMAIL=contacto@clinica.cl
DOCTOR_EMAIL=secretaria@clinica.cl   # Recibe notificación de cada nueva cita
EMAIL_DOMAIN=clinica.cl              # Dominio para emails de envío (debe estar en Resend)

# ─── Google (Service Account) ─────────────────────────────────────────────────
# 1. Crear proyecto en console.cloud.google.com
# 2. Activar APIs: Google Calendar API + Google Sheets API
# 3. Crear Service Account → Generar JSON key
# 4. Codificar: base64 -w 0 credentials.json
# 5. Compartir el calendario con el email del Service Account (como editor)
# 6. Compartir el Google Sheet con el email del Service Account (como editor)
GOOGLE_SERVICE_ACCOUNT_JSON=   # JSON del Service Account en base64
GOOGLE_CALENDAR_ID=            # ID del calendario (ej: abc@group.calendar.google.com)
GOOGLE_SPREADSHEET_ID=         # ID del Google Sheet (de la URL)

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=

# ─── IA conversacional (Claude Haiku) ────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Acceso a /dashboard → /dashboard?token=TU_TOKEN
DASHBOARD_TOKEN=

# ─── Notas de configuración ──────────────────────────────────────────────────
# HORARIOS DISPONIBLES: En el calendario del doctor, crear eventos con título
# exactamente "DISPONIBLE" para los horarios que el bot puede ofrecer a pacientes.
# Cuando un paciente confirma una cita, el bot renombra el evento automáticamente.
#
# GOOGLE SHEETS: Crear una hoja llamada "Citas" con estos encabezados en la fila 1:
# ID | Timestamp | Teléfono | Nombre | RUT | Email |
# Tratamiento | Urgente | Fecha Cita | Hora Cita | Estado | Notas
